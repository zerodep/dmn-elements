{
  "name": "dmn-elements",
  "version": "0.0.1",
  "description": "Executable decision elements based on DMN 1.3",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./src/index.js",
  "jsnext:main": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./dist/index.js",
      "import": "./src/index.js"
    },
    "./errors": {
      "types": "./types/index.d.ts",
      "require": "./dist/error/Errors.js",
      "import": "./src/error/Errors.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "test": "mocha -R @bonniernews/hot-bev -p -t 3000",
    "posttest": "npm run lint && npm run test:md",
    "test:md": "texample ./docs/Examples.md,./README.md",
    "lint": "eslint . --cache && prettier . --check --cache && npm run typecheck",
    "pretypecheck": "npm run build:types",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run dist",
    "cov:html": "c8 -r html -r text mocha -R @bonniernews/hot-bev -p -t 3000",
    "test:lcov": "c8 -r lcov mocha && npm run lint",
    "dist": "rollup -c && npm run build:types",
    "build:types": "node scripts/build-types.js"
  },
  "author": {
    "name": "Pål Edman",
    "url": "https://github.com/paed01"
  },
  "license": "MIT",
  "keywords": [
    "dmn",
    "dmn 1.3",
    "decision",
    "decision table",
    "drg",
    "feel",
    "isomorphic",
    "tree-shakeable"
  ],
  "files": [
    "dist",
    "src",
    "types",
    "*.d.ts"
  ],
  "c8": {
    "include": [
      "src/**/*"
    ]
  },
  "dependencies": {
    "feelin": "^7.0.1"
  },
  "devDependencies": {
    "@bonniernews/hot-bev": "^0.4.0",
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.13",
    "@types/luxon": "^3.7.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.40",
    "c8": "^11.0.0",
    "chai": "^6.2.1",
    "chronokinesis": "^8.0.0",
    "debug": "^4.3.4",
    "dmn-moddle": "^12.0.1",
    "dts-buddy": "^0.8.0",
    "eslint": "^10.6.0",
    "globals": "^17.0.0",
    "mocha": "^11.0.1",
    "mocha-cakes-2": "^3.3.0",
    "prettier": "^3.2.5",
    "rollup": "^4.24.0",
    "texample": "^1.0.2"
  }
}
